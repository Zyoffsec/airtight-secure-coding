<%- include('partials/header') %>

<section class="card">
  <h1>Профиль</h1>
  <dl class="profile">
    <dt>ID</dt>
    <dd><%= user.id %></dd>

    <dt>Имя пользователя</dt>
    <dd><%= user.username %></dd>

    <dt>Email</dt>
    <dd><%= user.email %></dd>

    <dt>Дата регистрации</dt>
    <dd><%= user.created_at %></dd>
  </dl>

  <form action="/logout" method="post">
    <button type="submit" class="btn btn-ghost">Выйти</button>
  </form>
</section>

<%- include('partials/footer') %>
